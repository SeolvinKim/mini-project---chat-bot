# 라우팅(mini)·생성(품질)·임베딩 모두 OpenAI
OPENAI_API_KEY=
APP_ENV=development
LOG_LEVEL=INFO

# --- TTS (음성 합성) ---
# 우선 시도할 엔진. azure 실패 시 openai 로 자동 폴백.
TTS_PROVIDER=azure

# Azure Speech: Azure Portal > "Speech service" 리소스 생성 후 키/위치(region) 입력
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=koreacentral
# 한국 여성 음성 후보: SunHi / JiMin / SeoHyeon / SoonBok / YuJin
AZURE_TTS_VOICE=ko-KR-SunHiNeural
# 차분·부드러운 톤(모든 음성에서 동작). 비우면 기본 톤.
AZURE_TTS_RATE=-12%
AZURE_TTS_PITCH=-8%
# express-as 스타일(지원 음성에서만). 미지원 음성에 넣으면 합성이 실패하니 보통 비워둠.
AZURE_TTS_STYLE=

# OpenAI TTS(폴백 엔진). voice: alloy/echo/fable/onyx/nova/shimmer
TTS_MODEL=tts-1
TTS_VOICE=alloy
