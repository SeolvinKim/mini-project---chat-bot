# 라우팅(mini)·생성(품질)·임베딩 모두 OpenAI
OPENAI_API_KEY=
APP_ENV=development
LOG_LEVEL=INFO

# --- TTS (음성 합성) ---
# 우선 엔진. openai 기본, 실패 시 azure 폴백(azure 키가 있을 때만).
TTS_PROVIDER=openai

# OpenAI TTS (기본 엔진)
# 모델: gpt-4o-mini-tts(최신·한국어 자연스럽고 말투 지정 가능) / tts-1 / tts-1-hd
TTS_MODEL=gpt-4o-mini-tts
# voice: alloy ash ballad coral echo fable nova onyx sage shimmer verse
TTS_VOICE=nova
# 말투(gpt-4o-mini-tts 에서만 반영). 비우면 기본 말투.
OPENAI_TTS_INSTRUCTIONS=한국어로 차분하고 부드럽게, 친근한 상담원 말투로 또박또박 읽어 주세요.

# Azure Speech (선택: 한국 여성 음성 ko-KR-* 를 쓰려면). Azure Portal > "Speech service"
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=koreacentral
AZURE_TTS_VOICE=ko-KR-SunHiNeural
AZURE_TTS_RATE=-12%
AZURE_TTS_PITCH=-8%
AZURE_TTS_STYLE=
